# Used by `vite build` for mainnet. Pinned to the canister IDs in
# `../.icp/data/mappings/ic.ids.json` (formerly `canister_ids.json`).
#
# The frontend's II-instance toggle picks between `id.ai` and `beta.id.ai`
# at runtime; leaving VITE_II_URL_* unset lets `defaultII()` pick the
# right URL for this host. Set them here only if you want to pin to a
# non-standard II host for this build.
VITE_BAGEL_CANISTER_ID=umeux-raaaa-aaaad-agnyq-cai
VITE_IC_HOST=https://icp0.io
