# Copy to `.env.local` for local dev or `.env.production` for mainnet build.
# Vite injects these into `import.meta.env` at build time — re-run `npm run
# build` after changing them.

# The bagel canister id. Locally: check the output of `icp canister status
# bagel --id-only`. Mainnet: pinned in `.icp/data/mappings/ic.ids.json`.
VITE_BAGEL_CANISTER_ID=uxrrr-q7777-77774-qaaaq-cai

# The IC HTTP gateway. Local replica (icp network start): http://127.0.0.1:4943
# Mainnet: https://icp0.io
VITE_IC_HOST=http://127.0.0.1:4943

# Internet Identity URL — `/authorize` is appended automatically. Optional
# overrides; when unset the frontend picks the right URL for the current
# host + II-instance-toggle value. See `defaultII()` in src/main.ts.
#
# Local:  https://id.ai.localhost:4943 / https://beta.id.ai.localhost:4943
# Mainnet: https://id.ai            / https://beta.id.ai
#VITE_II_URL_PROD=https://id.ai.localhost:4943
#VITE_II_URL_BETA=https://beta.id.ai.localhost:4943
