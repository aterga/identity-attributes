# Copy to `.env.local` for local dev or `.env.production` for mainnet build.
# Vite injects these into `import.meta.env` at build time — re-run `npm run
# build` after changing them.

# The bagel canister id. Locally: check `demos/bagel/.env` after
# `dfx deploy bagel`. Mainnet: the id `dfx deploy --network ic bagel` printed.
VITE_BAGEL_CANISTER_ID=uxrrr-q7777-77774-qaaaq-cai

# The IC HTTP gateway. Local replica: http://127.0.0.1:4943
# Mainnet: https://icp0.io
VITE_IC_HOST=http://127.0.0.1:4943

# Internet Identity's frontend origin. Local: subdomain of the II canister
# on the local replica. Mainnet: https://id.ai
VITE_II_URL=http://rdmx6-jaaaa-aaaaa-aaadq-cai.localhost:4943
