{
  "version": 1,
  "canisters": {
    "bagel": {
      "type": "motoko",
      "main": "src/Main.mo"
    },
    "bagel_frontend": {
      "type": "assets",
      "source": ["frontend/dist"],
      "dependencies": ["bagel"]
    }
  },
  "defaults": {
    "build": {
      "packtool": "mops sources"
    }
  },
  "networks": {
    "local": {
      "bind": "127.0.0.1:4943",
      "type": "ephemeral"
    }
  },
  "output_env_file": ".env"
}
